{
  "entities": {
    "SOSIncident": {
      "title": "SOS Incident",
      "description": "An emergency incident reported by a student or staff member.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterPhone": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string", "enum": ["moderate", "serious", "critical"] },
        "description": { "type": "string" },
        "photoUrl": { "type": "string" },
        "victimName": { "type": "string" },
        "ucuId": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "campusZone": { "type": "string" },
            "specificLocation": { "type": "string" }
          }
        },
        "status": { "type": "string", "enum": ["received", "dispatched", "en_route", "arrived", "completed"] },
        "assignedResource": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ambulance", "boda"] },
            "id": { "type": "string" },
            "name": { "type": "string" },
            "phone": { "type": "string" }
          }
        },
        "timestamp": { "type": "number" },
        "auditTrail": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "number" },
              "note": { "type": "string" }
            }
          }
        }
      },
      "required": ["reporterId", "reporterName", "symptoms", "severity", "description", "location", "status", "timestamp"]
    },
    "ResourceStatus": {
      "title": "Resource Status",
      "description": "The status of an emergency resource (ambulance, boda, or staff).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["ambulance", "boda", "staff"] },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "on_call", "off_duty", "maintenance", "busy"] },
        "lastUpdated": { "type": "number" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "name", "status", "lastUpdated"]
    },
    "VoiceMessage": {
      "title": "Voice Message",
      "description": "A voice message or transcription sent during an incident.",
      "type": "object",
      "properties": {
        "incidentId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string" },
        "text": { "type": "string" },
        "audioUrl": { "type": "string" },
        "timestamp": { "type": "number" },
        "language": { "type": "string", "enum": ["en", "lg"] }
      },
      "required": ["incidentId", "senderId", "senderRole", "text", "timestamp", "language"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a UCU student, staff, or emergency responder.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["reporter", "nurse", "doctor", "driver", "boda_coordinator", "boda_rider"] },
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["uid", "email", "role", "name"]
    }
  },
  "firestore": {
    "/incidents/{incidentId}": {
      "schema": "SOSIncident",
      "description": "Collection of emergency incidents."
    },
    "/resources/{resourceId}": {
      "schema": "ResourceStatus",
      "description": "Collection of emergency resource statuses."
    },
    "/voice_messages/{messageId}": {
      "schema": "VoiceMessage",
      "description": "Collection of voice messages for incidents."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
