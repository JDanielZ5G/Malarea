{
  "entities": {
    "PatientReport": {
      "title": "Patient Report",
      "description": "A report submitted by a Community Health Volunteer about a patient's symptoms and AI diagnosis.",
      "type": "object",
      "properties": {
        "chvId": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "description": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "district": { "type": "string" }
          }
        },
        "aiDiagnosis": {
          "type": "object",
          "properties": {
            "possibleConditions": { "type": "array", "items": { "type": "string" } },
            "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "recommendation": { "type": "string" }
          }
        },
        "malnutritionScan": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["normal", "at_risk", "severe"] },
            "confidence": { "type": "number" },
            "notes": { "type": "string" }
          }
        },
        "timestamp": { "type": "number" }
      },
      "required": ["chvId", "patientId", "patientName", "age", "gender", "symptoms", "location", "timestamp"]
    },
    "OutbreakAlert": {
      "title": "Outbreak Alert",
      "description": "An alert generated by the AI system or an official about a potential disease outbreak.",
      "type": "object",
      "properties": {
        "district": { "type": "string" },
        "condition": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "affectedCount": { "type": "number" },
        "aiAnalysis": { "type": "string" },
        "timestamp": { "type": "number" },
        "isResolved": { "type": "boolean" }
      },
      "required": ["district", "condition", "severity", "affectedCount", "timestamp", "isResolved"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about a CHV or District Official.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["chv", "official"] },
        "name": { "type": "string" },
        "district": { "type": "string" }
      },
      "required": ["uid", "email", "role", "name", "district"]
    }
  },
  "firestore": {
    "/reports/{reportId}": {
      "schema": "PatientReport",
      "description": "Collection of patient symptom reports."
    },
    "/alerts/{alertId}": {
      "schema": "OutbreakAlert",
      "description": "Collection of outbreak alerts."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    }
  }
}
