rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields: uid, email, role, name, phone
    //
    // Collection: incidents
    // Document ID: {incidentId}
    // Fields: reporterId, reporterName, symptoms, severity, location, status, assignedResource, timestamp, auditTrail
    //
    // Collection: resources
    // Document ID: {resourceId}
    // Fields: type, name, status, lastUpdated, metadata
    //
    // Collection: voice_messages
    // Document ID: {messageId}
    // Fields: incidentId, senderId, senderRole, text, timestamp, language
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(roles) {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role in roles;
    }

    function isStaff() {
      return hasRole(['nurse', 'doctor', 'driver', 'boda_coordinator', 'admin']);
    }

    function isBoda() {
      return hasRole(['boda_rider']);
    }

    function isReporter() {
      return hasRole(['reporter']);
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin') ||
        (request.auth.token.email == "wjdaniel379@gmail.com" && request.auth.token.email_verified == true) ||
        (request.auth.token.email == "trizzydaniels352@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'name']) &&
             hasOnlyAllowedFields(['uid', 'email', 'role', 'name', 'phone']) &&
             data.uid == request.auth.uid &&
             data.role in ['reporter', 'nurse', 'doctor', 'driver', 'boda_coordinator', 'boda_rider', 'admin'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() < 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 20));
    }

    function isValidIncident(data) {
      return data.keys().hasAll(['reporterId', 'reporterName', 'symptoms', 'severity', 'location', 'status', 'timestamp']) &&
             hasOnlyAllowedFields(['id', 'reporterId', 'reporterName', 'reporterPhone', 'symptoms', 'severity', 'description', 'photoUrl', 'victimName', 'ucuId', 'location', 'status', 'assignedResource', 'timestamp', 'auditTrail', 'medicPickupRequired', 'medicPickupStatus']) &&
             data.reporterId is string &&
             data.reporterName is string && data.reporterName.size() < 100 &&
             data.symptoms is list && data.symptoms.size() < 20 &&
             data.severity in ['moderate', 'serious', 'critical'] &&
             data.status in ['received', 'dispatched', 'en_route', 'arrived', 'completed'] &&
             data.location is map &&
             data.location.lat is number && data.location.lng is number &&
             data.timestamp is number &&
             (!('victimName' in data) || (data.victimName is string && data.victimName.size() < 100)) &&
             (!('ucuId' in data) || (data.ucuId is string && data.ucuId.size() < 50)) &&
             (!('reporterPhone' in data) || (data.reporterPhone is string && data.reporterPhone.size() < 20));
    }

    function isValidResource(data) {
      return data.keys().hasAll(['type', 'name', 'status', 'lastUpdated']) &&
             hasOnlyAllowedFields(['id', 'type', 'name', 'status', 'lastUpdated', 'metadata']) &&
             data.type in ['ambulance', 'boda', 'staff'] &&
             data.status in ['available', 'on_call', 'off_duty', 'maintenance', 'busy'] &&
             data.name is string && data.name.size() < 100 &&
             data.lastUpdated is number;
    }

    function isValidVoiceMessage(data) {
      return data.keys().hasAll(['incidentId', 'senderId', 'senderRole', 'text', 'timestamp', 'language']) &&
             hasOnlyAllowedFields(['id', 'incidentId', 'senderId', 'senderRole', 'text', 'audioUrl', 'timestamp', 'language']) &&
             data.incidentId is string &&
             data.senderId == request.auth.uid &&
             data.text is string && data.text.size() < 1000 &&
             data.timestamp is number &&
             data.language in ['en', 'lg'];
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                      (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /incidents/{incidentId} {
      allow read: if isStaff() || isAdmin() ||
                    (isReporter() && request.auth.uid == resource.data.reporterId) ||
                    (isBoda() && (resource.data.status == 'dispatched' || request.auth.uid == resource.data.assignedResource.id));
      
      allow create: if (isReporter() || isAdmin()) && isValidIncident(request.resource.data) && request.resource.data.reporterId == request.auth.uid;
      
      allow update: if (isStaff() && isValidIncident(request.resource.data)) || 
                      isAdmin() ||
                      (isReporter() && request.auth.uid == resource.data.reporterId && isValidIncident(request.resource.data) && areImmutableFieldsUnchanged(['reporterId'])) ||
                      (isBoda() && request.auth.uid == resource.data.assignedResource.id && isValidIncident(request.resource.data) && areImmutableFieldsUnchanged(['reporterId', 'severity', 'location']));
      
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create: if (isStaff() || isAdmin()) && isValidResource(request.resource.data);
      allow update: if (isStaff() || isAdmin() || (isBoda() && request.auth.uid == resourceId)) && isValidResource(request.resource.data);
      allow delete: if isAdmin();
    }

    match /voice_messages/{messageId} {
      allow read: if isAuthenticated(); 
      allow create: if isAuthenticated() && isValidVoiceMessage(request.resource.data);
    }
  }
}
